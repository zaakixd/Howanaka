# ─── Discord Bot & OAuth2 ────────────────────────────────────────────────────
# From https://discord.com/developers/applications

# Your bot's secret token (Bot tab → Token)
DISCORD_TOKEN=your_bot_token_here

# Your application's Client ID (General Information tab)
DISCORD_CLIENT_ID=your_client_id_here

# Your application's Client Secret (General Information tab)
DISCORD_CLIENT_SECRET=your_client_secret_here

# ─── Database ────────────────────────────────────────────────────────────────
# MongoDB Atlas connection string
# Get from: https://cloud.mongodb.com → Connect → Connect your application
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/discordbot?retryWrites=true&w=majority

# ─── Session & Security ──────────────────────────────────────────────────────
# Random string used to sign session cookies — use a long random value in production
SESSION_SECRET=change-this-to-a-random-secret-string-in-production

# ─── Deployment ──────────────────────────────────────────────────────────────
# URL where your dashboard is hosted (used for OAuth2 redirect URI)
# Development: leave blank (auto-detected)
# Production: https://your-vercel-app.vercel.app
DASHBOARD_URL=

# Port for the API server (auto-set by Replit/Render)
PORT=3000

# Environment (development | production)
NODE_ENV=development
